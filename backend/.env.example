# Copy to backend/.env and fill in values. Never commit the .env file.

# LLM provider (OpenAI-compatible: works for OpenAI, TokenRouter, Qwen Cloud, Z.ai, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_PROVIDER_NAME=OpenAI

# Optional: Bright Data for web research. If unset, falls back to httpx.get(lead.website).
BRIGHT_DATA_API_KEY=

# Demo fail-safe: when true, the seeded demo lead always returns a complete run
# even if the LLM or website fetch fails.
DEMO_MODE=true
DEMO_LEAD_ID=

# Auth + CORS
AUTH_SECRET_KEY=change-me-in-prod
ALLOW_REGISTRATION=true
# Comma-separated origins. Add the deployed frontend URL here.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
